# Google Business Profile API
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
GOOGLE_LOCATION_ID=locations/YOUR_LOCATION_ID
GOOGLE_ACCOUNT_ID=accounts/YOUR_ACCOUNT_ID

# Facebook Graph API
FACEBOOK_PAGE_ID=YOUR_PAGE_ID
FACEBOOK_PAGE_ACCESS_TOKEN=YOUR_PAGE_ACCESS_TOKEN

# Yelp Fusion API
YELP_API_KEY=YOUR_YELP_API_KEY
YELP_BUSINESS_ID=YOUR_YELP_BUSINESS_ID

# Notification Settings
WEBHOOK_URL=https://your-webhook-url.com/reviews
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFY_EMAIL=owner@yourbusiness.com

# Auto-Responder
AUTO_RESPOND_ENABLED=false
AUTO_RESPOND_MIN_RATING=4

# Sync Schedule (cron format)
SYNC_INTERVAL_MINUTES=60

# Jekyll Integration (local mode — optional)
# TESTIMONIAL_YML_PATH=/Volumes/floppy/GitHub/ohhsnap/_data/testimonial.yml

# GitHub Integration — push testimonial.yml to repo, triggers CloudCannon rebuild
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=your-username/ohhsnap
GITHUB_BRANCH=main
GITHUB_TESTIMONIAL_PATH=_data/testimonial.yml

# Server
HOST=0.0.0.0
PORT=8000
